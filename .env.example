# MJW GM Script Library environment template
# Copy this file to .env.local for local development. Do not commit real secrets.

# -----------------------------------------------------------------------------
# Browser-safe Vite variables
# Variables prefixed with VITE_ are bundled into the client application.
# Do not place private API keys, service tokens, or admin credentials here.
# -----------------------------------------------------------------------------

# Data mode options:
# - demo: use browser localStorage with seeded sample data.
# - pocketbase: use the PocketBase adapter for production persistence.
VITE_DATA_MODE=demo

# Public PocketBase URL used when VITE_DATA_MODE=pocketbase.
# Example: https://your-pocketbase-instance.example.com
VITE_POCKETBASE_URL=

# Optional deployment label for UI/debugging only.
# Recommended values: development, preview, production
VITE_APP_ENV=development

# -----------------------------------------------------------------------------
# Server-only variables for future Netlify Functions
# These must be configured in the Netlify dashboard or local Netlify environment.
# They must never be exposed through VITE_ variables.
# -----------------------------------------------------------------------------

# AI provider selector for a future server-side rewrite function.
# Supported planned values: openai, gemini
AI_PROVIDER=

# OpenAI key for future server-side AI script rewrite support.
OPENAI_API_KEY=

# Gemini key for future server-side AI script rewrite support.
GEMINI_API_KEY=

# Optional future server-side PocketBase service configuration.
# Only use these in Netlify Functions or another trusted server environment.
PB_SERVICE_URL=
PB_SUPERUSER_TOKEN=
